# ============================================================================
# XLNSCPP .gitignore
# ============================================================================

# --- Build directories ---
build/
cmake-build-*/
out/

# --- IDE / editor files ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Compiled objects / libraries ---
*.o
*.obj
*.a
*.lib
*.so
*.so.*
*.dylib
*.dll
*.exe

# --- CMake generated files ---
CMakeFiles/
CMakeCache.txt
cmake_install.cmake
CTestTestfile.cmake
Makefile
*.cmake
!CMakeLists.txt
!cmake/xlnsConfig.cmake.in

# --- Testing artifacts ---
Testing/
CTestCostData.txt
*.gcda
*.gcno
*.gcov

# --- Package files ---
*.tar.gz
*.zip
*.deb
*.rpm
